<header class="w-full sticky top-0 bg-[#fdf9f6]/95 backdrop-blur z-10 border-b border-[#d4c4b7]/30">
    <div class="px-4 md:px-6 py-4 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="flex items-center gap-6">
            <span class="font-headline font-extrabold tracking-widest text-lg md:text-xl text-[#7d5231] uppercase">Management Console</span>
            <nav class="hidden md:flex space-x-6">
                <a class="text-[#7d5231] border-b-2 border-[#7d5231] font-label text-xs uppercase tracking-widest py-1" href="#">Overview</a>
                <a class="text-[#1c1b1a] hover:bg-[#e5e2df] transition-colors font-label text-xs uppercase tracking-widest py-1" href="#manifest">Manifests</a>
                <a class="text-[#1c1b1a] hover:bg-[#e5e2df] transition-colors font-label text-xs uppercase tracking-widest py-1" href="#insights">Analytics</a>
            </nav>
        </div>

        <div class="flex items-center space-x-3">
            <div class="hidden sm:flex items-center bg-[#f1edea] rounded-lg px-3 py-2 w-56 md:w-64">
