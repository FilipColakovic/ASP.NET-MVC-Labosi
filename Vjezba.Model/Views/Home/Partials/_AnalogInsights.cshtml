@model Vjezba.Model.Models.ObjectOverviewViewModel

@{
    var delayedCount = Model.Deliveries.Count(d => d.IsDelayed);
}

<div id="insights" class="grid grid-cols-1 md:grid-cols-3 gap-6 rise-in" style="animation-delay: 260ms;">
    <div class="bg-surface-container-high rounded-xl p-6 relative overflow-hidden group">
        <div class="absolute top-0 left-0 w-1 h-full bg-primary"></div>
        <h3 class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant mb-4">Courier Capacity</h3>
        <p class="font-headline text-3xl font-bold text-primary">@Model.Couriers.Count</p>
        <p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant mt-2">Registered couriers in network</p>
    </div>

    <div class="bg-surface-container-high rounded-xl p-6 relative overflow-hidden group">
        <div class="absolute top-0 left-0 w-1 h-full bg-secondary"></div>
        <h3 class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant mb-2">Transit Bottlenecks</h3>
        <div class="flex items-center space-x-3 mt-4">
            <span class="material-symbols-outlined text-secondary">hub</span>
            <div>
                <p class="text-xs font-bold text-on-surface">Delayed deliveries</p>
                <p class="text-[10px] font-label text-on-surface-variant uppercase">@delayedCount currently delayed</p>
            </div>
        </div>
    </div>

    <div class="bg-surface-container-high rounded-xl p-6 relative overflow-hidden group">
        <div class="absolute top-0 left-0 w-1 h-full bg-tertiary"></div>
        <h3 class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant mb-2">Regional Stamps</h3>
        <div class="flex flex-wrap gap-2 mt-2">
            @foreach (var city in Model.Addresses.Select(a => a.City).Distinct().Take(6))
            {
                <span class="bg-surface-container px-2 py-1 rounded font-label text-[9px] uppercase tracking-tighter text-on-surface-variant">@city</span>
            }
        </div>
    </div>
</div>

