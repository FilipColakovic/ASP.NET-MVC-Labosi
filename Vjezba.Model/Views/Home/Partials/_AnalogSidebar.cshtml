@model Vjezba.Model.Models.ObjectOverviewViewModel?

@{
    var selectedType = (ViewData["SelectedType"]?.ToString() ?? "package").ToLowerInvariant();
}

<aside class="analog-sidebar analog-sidebar-surface hidden lg:flex sticky top-0 h-screen w-64 flex-col p-4 space-y-2 shrink-0" data-analog-sidebar>
    <div class="mb-8 px-2 pt-4">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-primary-container rounded-lg flex items-center justify-center text-on-primary-container">
                <span class="material-symbols-outlined">package_2</span>
            </div>
            <div class="analog-sidebar-brand-text min-w-0">
                <h1 class="text-lg font-bold font-headline text-[#7d5231]">The Analog Log</h1>
                <p class="font-label text-[10px] uppercase tracking-wider text-[#62574d]">Technical Operations</p>
            </div>
            <button type="button" class="analog-sidebar-toggle ml-auto h-9 w-9 rounded-md text-stone-600 hover:bg-[#e5e2df] transition-colors" data-analog-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true" title="Collapse sidebar">
                <span class="material-symbols-outlined" data-analog-sidebar-toggle-icon>chevron_left</span>
            </button>
        </div>
    </div>

    <nav class="flex-1 space-y-1">
        <a class="analog-sidebar-link flex items-center gap-3 px-4 py-3 rounded-md transition-transform hover:scale-[1.01] active:scale-95 font-label text-sm uppercase tracking-wider @(selectedType == "package" ? "text-[#7a4c2b] font-bold bg-[#e5e2df]" : "text-[#62574d] hover:text-[#7a4c2b] hover:bg-[#e5e2df]/50")" asp-action="Index" asp-controller="Home" asp-route-selectedType="package" title="Packages">
            <span class="material-symbols-outlined">package_2</span>
            <span class="analog-sidebar-text">Packages</span>
        </a>
        <a class="analog-sidebar-link flex items-center gap-3 px-4 py-3 rounded-md transition-transform hover:scale-[1.01] active:scale-95 font-label text-sm uppercase tracking-wider @(selectedType == "courier" ? "text-[#7a4c2b] font-bold bg-[#e5e2df]" : "text-[#62574d] hover:text-[#7a4c2b] hover:bg-[#e5e2df]/50")" asp-action="Index" asp-controller="Home" asp-route-selectedType="courier" title="Couriers">
            <span class="material-symbols-outlined">local_shipping</span>
            <span class="analog-sidebar-text">Couriers</span>
        </a>
        <a class="analog-sidebar-link flex items-center gap-3 px-4 py-3 rounded-md transition-transform hover:scale-[1.01] active:scale-95 font-label text-sm uppercase tracking-wider @(selectedType == "warehouse" ? "text-[#7a4c2b] font-bold bg-[#e5e2df]" : "text-[#62574d] hover:text-[#7a4c2b] hover:bg-[#e5e2df]/50")" asp-action="Index" asp-controller="Home" asp-route-selectedType="warehouse" title="Warehouses">
            <span class="material-symbols-outlined">warehouse</span>
            <span class="analog-sidebar-text">Warehouses</span>
        </a>
        <a class="analog-sidebar-link flex items-center gap-3 px-4 py-3 rounded-md transition-transform hover:scale-[1.01] active:scale-95 font-label text-sm uppercase tracking-wider @(selectedType == "user" ? "text-[#7a4c2b] font-bold bg-[#e5e2df]" : "text-[#62574d] hover:text-[#7a4c2b] hover:bg-[#e5e2df]/50")" asp-action="Index" asp-controller="Home" asp-route-selectedType="user" title="Users">
            <span class="material-symbols-outlined">group</span>
            <span class="analog-sidebar-text">Users</span>
        </a>
        <a class="analog-sidebar-link flex items-center gap-3 px-4 py-3 rounded-md transition-transform hover:scale-[1.01] active:scale-95 font-label text-sm uppercase tracking-wider @(selectedType == "delivery" ? "text-[#7a4c2b] font-bold bg-[#e5e2df]" : "text-[#62574d] hover:text-[#7a4c2b] hover:bg-[#e5e2df]/50")" asp-action="Index" asp-controller="Home" asp-route-selectedType="delivery" title="Status Logs">
            <span class="material-symbols-outlined">receipt_long</span>
            <span class="analog-sidebar-text">Status Logs</span>
        </a>
    </nav>

    <div class="mt-auto space-y-1">
        <button class="analog-sidebar-link w-full bg-secondary-container text-on-secondary-container py-3 rounded-md font-label text-xs font-bold uppercase tracking-widest transition-transform hover:scale-[1.01] active:scale-95 mb-4 flex items-center justify-center gap-2" title="Track Package">
            <span class="material-symbols-outlined text-[18px]">search</span>
            <span class="analog-sidebar-text">Track Package</span>
        </button>
        <a class="analog-sidebar-link flex items-center gap-3 px-4 py-3 text-[#62574d] hover:bg-[#e5e2df]/50 rounded-md font-label text-sm uppercase tracking-wider" href="#" title="Support">
            <span class="material-symbols-outlined">help</span>
            <span class="analog-sidebar-text">Support</span>
        </a>
        <a class="analog-sidebar-link flex items-center gap-3 px-4 py-3 text-[#62574d] hover:bg-[#e5e2df]/50 rounded-md font-label text-sm uppercase tracking-wider" asp-action="Privacy" asp-controller="Home" title="Privacy">
            <span class="material-symbols-outlined">logout</span>
            <span class="analog-sidebar-text">Privacy</span>
        </a>
    </div>
</aside>
