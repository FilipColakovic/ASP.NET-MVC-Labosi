@model Vjezba.Model.Models.ObjectOverviewViewModel
@{
    Layout = null;
    ViewData["Title"] = "The Analog Log - Management Console";
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="~/js/index-analog-log-tailwind-config.js" asp-append-version="true"></script>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/index-analog-log.css" asp-append-version="true" />
    <script src="~/js/site.js" asp-append-version="true" defer></script>
</head>
<body class="bg-surface font-body text-on-surface flex min-h-screen">
    <partial name="Partials/_AnalogSidebar" model="Model" />

    <main class="index-canvas-bg flex-1 flex flex-col min-w-0 overflow-hidden relative">
        <div class="absolute inset-0 grain-overlay"></div>

        <partial name="Partials/_AnalogTopbar" />

        <div class="p-4 md:p-8 space-y-8 overflow-y-auto relative">
            <partial name="Partials/_AnalogManifestSection" model="Model" />
            <partial name="Partials/_AnalogInsights" model="Model" />
        </div>
    </main>

    <partial name="Partials/_AnalogFab" />
</body>
</html>
